{
  "name": "manager-io-crypto",
  "version": "1.0.0",
  "description": "Software de gestión empresarial con soporte crypto",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "tsx watch src/backend/index.ts",
    "dev:frontend": "vite",
    "build": "tsc && vite build",
    "start": "node dist/backend/index.js"
  },
  "dependencies": {
    "@cashu/cashu-ts": "^3.6.1",
    "@reown/appkit": "^1.8.19",
    "@reown/appkit-adapter-solana": "^1.8.19",
    "@reown/appkit-adapter-wagmi": "^1.8.19",
    "@solana/wallet-adapter-base": "^0.9.27",
    "@solana/wallet-adapter-react": "^0.15.39",
    "@solana/wallet-adapter-wallets": "^0.19.37",
    "@solana/web3.js": "^1.98.4",
    "@tanstack/react-query": "^5.94.5",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^9.4.3",
    "bip39": "^3.1.0",
    "bs58": "^6.0.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0",
    "viem": "^2.47.6",
    "wagmi": "^2.19.5"
