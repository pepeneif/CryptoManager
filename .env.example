# CryptoManager Environment Configuration
# Copy this file to .env and update the values

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=3001
NODE_ENV=development

# JWT Secret (generate a secure random string for production)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Database (optional - defaults to ./data/manager.db)
# DATABASE_URL=./data/manager.db

# Frontend URL (for CORS in production)
# FRONTEND_URL=http://localhost:3000

# ============================================
# BLOCKCHAIN RPC URLs
# ============================================
# Get free RPC URLs from Alchemy, Infura, or similar
# Default values use Alchemy demo endpoints (limited usage)
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/demo
POLY_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/demo
ARBI_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/demo
OPTI_RPC_URL=https://opt-mainnet.g.alchemy.com/v2/demo
BSC_RPC_URL=https://bsc-dataseed.binance.org

# ============================================
# BLOCKCHAIN EXPLORER API KEYS
# ============================================
# Get free API keys from:
# - Etherscan.io (Ethereum)
# - Polygonscan.com (Polygon)
# - Arbiscan.io (Arbitrum)
# - BscScan.com (BSC)
#ETHERSCAN_API_KEY=your-etherscan-api-key
#POLYGONSCAN_API_KEY=your-polygonscan-api-key
#ARBISCAN_API_KEY=your-arbiscan-api-key
#BSCSCAN_API_KEY=your-bscscan-api-key

# ============================================
# PRICE FEEDS (optional)
# ============================================
# CoinGecko API (free, no key needed for basic usage)
# COINGECKO_API_URL=https://api.coingecko.com/api/v3